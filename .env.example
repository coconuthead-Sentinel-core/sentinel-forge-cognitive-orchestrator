# Sentinel Forge Configuration Example
# Copy this file to .env and update with your actual values

# --- Core Application ---
PROJECT_NAME=Sentinel Forge
VERSION=2.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_KEY=secret

# --- AI Provider (Azure OpenAI) ---
# Leave empty to use Mock AI mode
AOAI_ENDPOINT=
AOAI_KEY=
AOAI_CHAT_DEPLOYMENT=gpt-4
AOAI_EMBED_DEPLOYMENT=text-embedding-ada-002
AOAI_API_VERSION=2024-08-01-preview
AI_TEMPERATURE=0.7

# --- Mock Mode ---
# Set to true to run without external AI service
MOCK_AI=true

# --- Infrastructure (Cosmos DB) ---
# Leave COSMOS_KEY empty to use Mock DB mode
COSMOS_ENDPOINT=https://localhost:8081/
COSMOS_KEY=
COSMOS_DATABASE_NAME=SentinelForgeDB
COSMOS_CONTAINER_NAME=Items

# --- Cognitive Zones ---
ZONE_ACTIVE_THRESHOLD=0.7
ZONE_PATTERN_THRESHOLD=0.3

# --- Performance ---
RATE_LIMIT_QPS=10.0
