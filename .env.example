# Sentinel Forge Configuration Example
# Copy this file to .env and fill in your values

# ========================================
# Core Application Settings
# ========================================
PROJECT_NAME=Sentinel Forge
VERSION=2.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Security
API_KEY=secret

# ========================================
# AI Provider Configuration
# ========================================
# Set MOCK_AI=true for development without Azure OpenAI
MOCK_AI=true

# Azure OpenAI Configuration (only needed if MOCK_AI=false)
AOAI_ENDPOINT=
AOAI_KEY=
AOAI_CHAT_DEPLOYMENT=gpt-4
AOAI_EMBED_DEPLOYMENT=text-embedding-ada-002
AOAI_API_VERSION=2024-08-01-preview

# ========================================
# Infrastructure (Cosmos DB)
# ========================================
# Leave COSMOS_KEY empty to use Mock DB mode (no external dependencies)
COSMOS_ENDPOINT=https://localhost:8081/
COSMOS_KEY=
COSMOS_DATABASE_NAME=SentinelForgeDB
COSMOS_CONTAINER_NAME=Items

# ========================================
# Performance Settings
# ========================================
RATE_LIMIT_QPS=10.0

# ========================================
# Quick Start Guide
# ========================================
# For local development:
# 1. Copy this file to .env
# 2. Keep MOCK_AI=true and COSMOS_KEY empty for zero external dependencies
# 3. Run: uvicorn backend.main:app --reload --port 8000
# 4. Access API at: http://localhost:8000/api/status
# 5. View docs at: http://localhost:8000/docs
#
# For production with Azure:
# 1. Set MOCK_AI=false
# 2. Fill in AOAI_ENDPOINT and AOAI_KEY
# 3. Fill in COSMOS_KEY for persistent storage
# 4. Set ENVIRONMENT=production
